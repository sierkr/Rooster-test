// ============================================================================
// Firestore Security Rules - Indeling Radiologen
// ============================================================================
//
// Rollen:
//   beheerder     - volledig beheer: planning, gebruikers, stamgegevens
//   radioloog     - eigen week lezen, hele rooster lezen, vakantie/wensen/opm
//   secretariaat  - alles lezen, opmerkingen toevoegen bij elke dag
//   lezer         - alleen lezen
//
// De eerste beheerder wordt handmatig in Firestore aangemaakt door de project-
// eigenaar. Daarna kunnen beheerders andere gebruikers aanmaken en rollen
// toekennen via de app.
// ============================================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------------
    // Helper functies
    // -----------------------------------------------------------------------
    function isIngelogd() {
      return request.auth != null;
    }

    function gebruiker() {
      return get(/databases/$(database)/documents/gebruikers/$(request.auth.uid)).data;
    }

    function rolIs(rol) {
      return isIngelogd() && gebruiker().rol == rol;
    }

    function isBeheerder() {
      return rolIs('beheerder');
    }

    function isRadioloog() {
      return rolIs('radioloog');
    }

    function isSecretariaat() {
      return rolIs('secretariaat');
    }

    function isLezer() {
      return rolIs('lezer') || rolIs('technician');
    }

    function magLezen() {
      // Iedere ingelogde gebruiker met een geldige rol mag lezen
      return isIngelogd() && gebruiker().rol in ['beheerder', 'radioloog', 'secretariaat', 'lezer', 'technician'];
    }

    function eigenRadioloogId() {
      // Koppelt ingelogde gebruiker aan radioloog-document
      return gebruiker().radioloog_id;
    }

    // v3.28.0: effectieve wijzig-permissie, gespiegeld aan de client-logica
    // (helpers.js/permissie): rol 'beheerder' heeft mag_beheer standaard;
    // andere rollen alleen als de permissies-map het expliciet toekent.
    function heeftMagBeheer() {
      return isIngelogd() && (
        gebruiker().rol == 'beheerder'
        || gebruiker().get('permissies', {}).get('mag_beheer', false) == true
      );
    }

    // -----------------------------------------------------------------------
    // v3.28.0 (K2): schema-bewaking voor indeling-documenten.
    // - indelingVeldenOk: alleen bekende veldnamen (bewaakt bij CREATE; bij
    //   update niet, zodat een restore van een oudere backup met een inmiddels
    //   vervallen veld niet halverwege strandt — zie DEPLOY-FASE1.md).
    // - indelingTypesOk: kritieke velden hebben het juiste type en het
    //   datum-veld komt altijd overeen met het document-id.
    // -----------------------------------------------------------------------
    function indelingVeldenOk() {
      return request.resource.data.keys().hasOnly([
        'datum', 'weeknr', 'dag', 'toewijzingen', 'dienst', 'bespreking',
        'interventie', 'opmerking', 'cel_opmerkingen', 'vakantie_v',
        'vakantie_min', 'vakantie_rank', 'vakantie_geaccordeerd', 'vakantie_x'
      ]);
    }

    function indelingTypesOk(datum) {
      let d = request.resource.data;
      return (!('datum' in d) || d.datum == datum)
          && (!('toewijzingen' in d) || d.toewijzingen is map)
          && (!('cel_opmerkingen' in d) || d.cel_opmerkingen is map)
          && (!('vakantie_v' in d) || d.vakantie_v is map)
          && (!('dienst' in d) || d.dienst is map)
          && (!('weeknr' in d) || d.weeknr is int)
          && (!('dag' in d) || d.dag is string);
    }

    // Check: radioloog mag alleen vakantie_v op zijn eigen radId-kolom wijzigen.
    // Alle andere velden moeten ongemoeid blijven.
    function radioloogMagVakantieToggelen() {
      let eigen = eigenRadioloogId();
      let geraakt = request.resource.data.diff(resource.data).affectedKeys();
      return eigen != null
          && geraakt.hasOnly(['vakantie_v', 'datum'])
          && (!geraakt.hasAny(['vakantie_v']) ||
              request.resource.data.get('vakantie_v', {})
                .diff(resource.data.get('vakantie_v', {}))
                .affectedKeys().hasOnly([eigen]));
    }

    // -----------------------------------------------------------------------
    // gebruikers/ - gebruikersprofielen (koppeling auth -> rol + radioloog)
    // -----------------------------------------------------------------------
    match /gebruikers/{uid} {
      // Gebruiker mag eigen profiel lezen, beheerders mogen alles
      allow read: if isBeheerder() || request.auth.uid == uid;

      // Alleen beheerders mogen gebruikers aanmaken, rollen wijzigen, verwijderen
      allow create, delete: if isBeheerder();

      // Update: beheerders mogen alles. Andere gebruikers mogen op hun eigen
      // profiel UITSLUITEND (v3.28.0/M4, whitelist i.p.v. blacklist):
      //   - naam                  (eigen weergavenaam)
      //   - wachtwoord_gewijzigd  (alleen op true te zetten, bij eerste login)
      //   - agenda_token          (string of null; eigen iCal-koppeling)
      // Rol, radioloog_id, permissies, email en alle toekomstige velden zijn
      // daarmee automatisch beschermd.
      allow update: if isBeheerder()
                    || (request.auth.uid == uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['naam', 'wachtwoord_gewijzigd', 'agenda_token'])
                        && (!request.resource.data.diff(resource.data).affectedKeys()
                               .hasAny(['wachtwoord_gewijzigd'])
                            || request.resource.data.wachtwoord_gewijzigd == true)
                        && (!request.resource.data.diff(resource.data).affectedKeys()
                               .hasAny(['agenda_token'])
                            || request.resource.data.agenda_token is string
                            || request.resource.data.agenda_token == null)
                        && (!request.resource.data.diff(resource.data).affectedKeys()
                               .hasAny(['naam'])
                            || request.resource.data.naam is string
                            || request.resource.data.naam == null));
    }

    // -----------------------------------------------------------------------
    // radiologen/ - stamgegevens radiologen
    // -----------------------------------------------------------------------
    match /radiologen/{id} {
      allow read: if magLezen();
      allow write: if isBeheerder();
    }

    // -----------------------------------------------------------------------
    // functies/ - stamgegevens functiecodes
    // -----------------------------------------------------------------------
    match /functies/{id} {
      allow read: if magLezen();
      allow write: if isBeheerder();
    }

    // -----------------------------------------------------------------------
    // besprekingen/ - stamgegevens besprekingen
    // -----------------------------------------------------------------------
    match /besprekingen/{id} {
      allow read: if magLezen();
      allow write: if isBeheerder();
    }

    // -----------------------------------------------------------------------
    // validatie_regels/ - Crit.func regels
    // -----------------------------------------------------------------------
    match /validatie_regels/{id} {
      allow read: if magLezen();
      allow write: if isBeheerder();
    }

    // -----------------------------------------------------------------------
    // indeling/{datum} - het hoofdrooster, één doc per dag
    // -----------------------------------------------------------------------
    match /indeling/{datum} {
      allow read: if magLezen();

      // Create: wijzig-gerechtigden (rol beheerder of expliciete mag_beheer-
      // permissie) mogen alles — mits het doc het bekende schema volgt (K2).
      // Radiologen mogen een nieuw indeling-doc aanmaken om vakantie_v op een
      // dag zonder bestaande indeling te zetten, maar alleen voor hun eigen
      // radId-kolom.
      allow create: if (heeftMagBeheer() && indelingVeldenOk() && indelingTypesOk(datum))
                    || (isRadioloog()
                        && eigenRadioloogId() != null
                        && request.resource.data.keys().hasOnly(['datum', 'vakantie_v'])
                        && request.resource.data.get('vakantie_v', {})
                             .keys().hasOnly([eigenRadioloogId()]));
      allow delete: if isBeheerder();

      // Update regels per rol:
      // - Wijzig-gerechtigden: alles, mits kritieke velden het juiste type
      //   houden en het datum-veld het document-id blijft (K2)
      // - Radiologen: alleen vakantie_v op eigen radId-kolom
      // - Secretariaat / lezers zonder mag_beheer: niets (alleen lezen)
      allow update: if (heeftMagBeheer() && indelingTypesOk(datum))
                    || (isRadioloog() && radioloogMagVakantieToggelen());
    }

    // -----------------------------------------------------------------------
    // vakantie_rankings/ - ranking-tabellen voor vakantie-blokken
    // -----------------------------------------------------------------------
    match /vakantie_rankings/{naam} {
      allow read: if magLezen();
      allow write: if isBeheerder();
    }

    // -----------------------------------------------------------------------
    // wensen/ - vakantie- en voorkeursverzoeken door radiologen
    // -----------------------------------------------------------------------
    match /wensen/{id} {
      // Iedereen mag lezen (transparantie in de maatschap)
      allow read: if magLezen();

      // Radiologen mogen eigen wensen aanmaken; beheerders mogen alles
      allow create: if isBeheerder()
                    || (isRadioloog()
                        && request.resource.data.radioloog_id == eigenRadioloogId());
      allow update, delete: if isBeheerder()
                            || (isRadioloog() && resource.data.radioloog_id == eigenRadioloogId());
    }

    // -----------------------------------------------------------------------
    // wijzigingen/ - notificatie-log (append-only)
    // v3.28.0 (K3): create is aangescherpt. Voorheen mocht iedere ingelogde
    // gebruiker records met willekeurige inhoud aanmaken; nu alleen
    // wijzig-gerechtigden, met een vaste veldenset, een uid/email die
    // aantoonbaar van de schrijver zelf is, en een server-timestamp.
    // Het onvervalsbare audit-spoor staat daarnaast in audit_log/ en wordt
    // uitsluitend server-side geschreven (Cloud Function auditIndeling).
    // -----------------------------------------------------------------------
    match /wijzigingen/{id} {
      allow read: if isBeheerder()
                  || (isRadioloog() && resource.data.radioloog_id == eigenRadioloogId());
      allow create: if heeftMagBeheer()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.email == gebruiker().email
                    && request.resource.data.wanneer == request.time
                    && request.resource.data.keys().hasOnly([
                         'uid', 'email', 'datum', 'radioloog_id', 'van',
                         'naar', 'veld', 'wanneer', 'gezien'
                       ])
                    && request.resource.data.datum is string
                    && request.resource.data.gezien is bool;
      // Geen updates of deletes - log is onveranderlijk; alleen de eigen
      // gezien-vlag mag door de betrokken radioloog gezet worden
      allow update: if isRadioloog()
                    && resource.data.radioloog_id == eigenRadioloogId()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['gezien']);
      allow delete: if false;
    }

    // -----------------------------------------------------------------------
    // audit_log/ - onvervalsbaar audit-spoor (v3.28.0, K3)
    // Wordt uitsluitend geschreven door de Cloud Function auditIndeling
    // (Admin SDK, omzeilt deze rules). Clients kunnen nooit schrijven;
    // alleen beheerders kunnen lezen.
    // -----------------------------------------------------------------------
    match /audit_log/{id} {
      allow read: if isBeheerder();
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // bezetting_mutaties/ - logboek van stoel-ingrepen (voor terugdraaien)
    // -----------------------------------------------------------------------
    match /bezetting_mutaties/{id} {
      allow read: if isBeheerder();
      allow write: if isBeheerder();
    }

    // -----------------------------------------------------------------------
    // instellingen/ - globale app-instellingen
    // -----------------------------------------------------------------------
    match /instellingen/{id} {
      allow read: if magLezen();
      allow write: if isBeheerder();
    }
  }
}
